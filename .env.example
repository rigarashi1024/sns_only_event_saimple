# =========================================
# GitHub Secrets に登録する値
# =========================================

# 通常の PR レビューで利用する主系の Gemini API キー
# 想定: Gemini の無料枠を利用するキー
GEMINI_API_KEY1=

# 主系のキーやモデルが枯渇した場合のみ利用するフォールバック用 Gemini API キー
# 想定: Gemini の有料枠を利用するキー
GEMINI_API_KEY2=

# フォールバック用の課金キーを使用した際に通知する Slack Incoming Webhook URL
SLACK_WEBHOOK_URL=

# =========================================
# GitHub Actions 実行時に注入される値
# =========================================

# GitHub API で PR 情報取得、変更ファイル取得、コメント投稿に利用するトークン
# GitHub Actions では通常 github.token から自動で渡されます
# 通常はリポジトリ設定に手動登録しません
GITHUB_TOKEN=

# レビュー対象の PR 番号
# GitHub Actions ではイベント情報から注入されます
# 例:
#   github.event.pull_request.number
#   github.event.issue.number
# 通常はリポジトリ設定に手動登録しません
PR_NUMBER=

# owner/repo 形式のリポジトリ名
# 例: your-org/your-repo
# GitHub Actions では通常 github.repository から注入されます
# 通常はリポジトリ設定に手動登録しません
REPO_FULL_NAME=

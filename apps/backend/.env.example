# Go バックエンド用のローカル環境変数例

# 実行環境
# local: 環境変数からローカル用設定を読む
# dev/prd: Secret Manager などクラウド環境向け設定を読む
APP_ENV=local

# API ポート
PORT=8081

# Firestore / Secret Manager で使う GCP project id
# local では PUBSUB_PROJECT_ID と同じ値でも動作する
GCP_PROJECT_ID=sns-only-event-local

# Firestore Emulator 接続先
FIRESTORE_EMULATOR_HOST=firestore-emulator:8080

# Pub/Sub Emulator 接続先
PUBSUB_EMULATOR_HOST=pubsub-emulator:8085

# ローカル開発用の Pub/Sub project id
PUBSUB_PROJECT_ID=sns-only-event-local

# ローカル暗号化キーの例
# 実運用では Secret Manager 管理を前提とする
TOKEN_ENCRYPTION_KEY=replace-with-local-dev-key

# dev/prd で TOKEN_ENCRYPTION_KEY を取得する Secret Manager 設定
TOKEN_ENCRYPTION_KEY_SECRET_ID=TOKEN_ENCRYPTION_KEY
TOKEN_ENCRYPTION_KEY_SECRET_VERSION=latest

# 認証 Cookie を含む CORS リクエストを許可するフロントエンド Origin
# 複数指定する場合はカンマ区切り
CORS_ALLOWED_ORIGINS=http://localhost:3001

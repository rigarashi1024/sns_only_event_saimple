# Go バックエンド用のローカル環境変数例

# 実行環境
# local: 環境変数からローカル用設定を読む
# dev/prd: Secret Manager などクラウド環境向け設定を読む
APP_ENV=local

# API ポート
PORT=8081

# Firestore Emulator 接続先
FIRESTORE_EMULATOR_HOST=firestore-emulator:8080

# Pub/Sub Emulator 接続先
PUBSUB_EMULATOR_HOST=pubsub-emulator:8085

# ローカル開発用の Pub/Sub project id
PUBSUB_PROJECT_ID=sns-only-event-local

# ローカル暗号化キーの例
# 実運用では Secret Manager 管理を前提とする
TOKEN_ENCRYPTION_KEY=replace-with-local-dev-key
